---
import CategoryGrid from "@components/CategoryGrid.astro";
import ContactButtons from "@components/ContactButtons.astro";
import ProductCard from "@components/ProductCard.astro";
import RequestForm from "@components/RequestForm.astro";
import YandexMap from "@components/YandexMap.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { categories, categoryPages, getPopularProducts, products } from "@lib/catalog";
import { faqSchema } from "@lib/schema";
import { site } from "@lib/site";

const popularProducts = getPopularProducts(6);
const heroWhatsappText = encodeURIComponent("Здравствуйте! Хочу узнать стоимость бетона и доставки.");
const faqItems = [
  {
    question: "Цены указаны с доставкой?",
    answer: site.priceNote
  },
  {
    question: "Можно ли заказать бетон по Московской области?",
    answer: "Да, заявки принимаются для объектов в Москве и Московской области. Стоимость доставки рассчитывается индивидуально."
  },
  {
    question: "Как быстро уточнить цену?",
    answer: "Оставьте заявку через форму, WhatsApp, MAX или позвоните по телефону. Для расчета нужны марка бетона, объем и адрес доставки."
  }
];
---

<BaseLayout title={site.title} description={site.description} structuredData={[faqSchema(faqItems)]}>
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">{site.legalName}</p>
        <h1>{site.title}</h1>
        <p class="lead">
          Каталог бетонных смесей, цены за 1 м³ и заявка на поставку бетона от завода.
          Работаем с объектами в Москве и Московской области.
        </p>
        <div class="hero-points" aria-label="Преимущества поставки">
          <span>Доставка по Москве и области</span>
          <span>Цены за 1 м³</span>
          <span>Расчет под объект</span>
        </div>
        <div class="hero-actions">
          <a class="button button-primary hero-catalog-cta" href="/catalog/">Смотреть каталог и цены</a>
          <a class="button button-whatsapp" href={`${site.whatsappHref}?text=${heroWhatsappText}`}>Написать в WhatsApp</a>
        </div>
        <div class="hero-stats" aria-label="Ключевые сведения">
          <div class="stat"><strong>{products.length}</strong><span>позиций в примере каталога</span></div>
          <div class="stat"><strong>{categories.length}</strong><span>категорий продукции</span></div>
          <div class="stat"><strong>1 м³</strong><span>базовая единица цены</span></div>
        </div>
      </div>
      <div class="hero-media">
        <img src="/images/lider-beton-hero-zavod.webp" alt="Бетонный завод ЛИДЕР БЕТОН ГРУПП" loading="eager" />
        <span class="hero-region-badge">Москва и МО</span>
        <div class="hero-media-card">
          <strong>Бетон, растворы и смеси</strong>
          <span>Подберем марку, объем и доставку под задачу</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section prices-section" id="prices">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Цены</p>
        <h2>Цены на бетон и строительные смеси</h2>
        <p>
          Выберите категорию, чтобы посмотреть актуальные позиции и стоимость за 1 м³.
          Итоговая стоимость доставки рассчитывается индивидуально.
        </p>
      </div>
      <CategoryGrid categories={categoryPages} variant="featured" />
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Популярные позиции</p>
        <h2>Бетон с доставкой от завода</h2>
      </div>
      <div class="grid grid-3">
        {popularProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <section class="section section-white">
    <div class="container home-info-section">
      <div class="section-title">
        <p class="eyebrow">Преимущества</p>
        <h2>Почему выбирают нас</h2>
      </div>
      <div class="home-info-grid">
        <article class="info-card why-card">
          <span class="info-card-icon" aria-hidden="true">01</span>
          <h3>Собственный завод</h3>
          <p>Собственный завод и поставка по Москве и МО.</p>
        </article>
        <article class="info-card why-card">
          <span class="info-card-icon" aria-hidden="true">02</span>
          <h3>Расчет доставки</h3>
          <p>Расчет доставки по адресу и объему.</p>
        </article>
        <article class="info-card why-card">
          <span class="info-card-icon" aria-hidden="true">03</span>
          <h3>Подбор марки</h3>
          <p>Подбор марки под задачу.</p>
        </article>
      </div>

      <div class="section-title order-title">
        <p class="eyebrow">Заказ</p>
        <h2>Как заказать</h2>
      </div>
      <div class="order-steps">
        <article class="order-step">
          <span>1</span>
          <h3>Связь</h3>
          <p>Связь через телефон и мессенджеры.</p>
        </article>
        <article class="order-step">
          <span>2</span>
          <h3>Адрес и объем</h3>
          <p>Расчет доставки по адресу и объему.</p>
        </article>
        <article class="order-step">
          <span>3</span>
          <h3>Марка</h3>
          <p>Подбор марки под задачу.</p>
        </article>
        <article class="order-step">
          <span>4</span>
          <h3>Поставка</h3>
          <p>Поставка по Москве и МО.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section request-section">
    <div class="container request-panel">
      <div class="request-copy">
        <div class="section-title">
          <p class="eyebrow">Заявка</p>
          <h2>Рассчитать бетон и доставку</h2>
          <p>Подберем марку под задачу и рассчитаем доставку по адресу и объему. Связаться можно через телефон и мессенджеры.</p>
        </div>
        <ul class="request-points">
          <li>Поставка по Москве и МО</li>
          <li>Расчет доставки по адресу и объему</li>
          <li>Подбор марки под задачу</li>
        </ul>
        <ContactButtons />
      </div>
      <RequestForm />
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Примеры работ</p>
        <h2>Галерея-заглушка для будущих фотографий</h2>
      </div>
      <div class="grid grid-3">
        {["Жилой комплекс, Москва", "Частный дом, Подмосковье", "Промышленный объект"].map((title) => (
          <article class="work-card">
            <img src="/images/product-placeholder.svg" alt="" loading="lazy" />
            <div class="work-card-body">
              <h3>{title}</h3>
              <p>Район/город и марка бетона будут уточнены после добавления реальных фотографий объекта.</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-white contact-map-section">
    <div class="container grid grid-2">
      <div>
        <div class="section-title">
          <p class="eyebrow">Карта</p>
          <h2>Контакты и точка завода</h2>
          <p>Связь через телефон и мессенджеры. Поставка по Москве и МО.</p>
        </div>
        <ContactButtons />
      </div>
      <YandexMap />
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">FAQ</p>
        <h2>Частые вопросы</h2>
      </div>
      <div class="grid">
        {faqItems.map((item) => (
          <details class="info-card">
            <summary><strong>{item.question}</strong></summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
