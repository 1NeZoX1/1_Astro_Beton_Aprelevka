---
import CategoryGrid from "@components/CategoryGrid.astro";
import MessengerIcons from "@components/MessengerIcons.astro";
import RequestSection from "@components/RequestSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { categoryPages } from "@lib/catalog";
import { faqSchema } from "@lib/schema";
import { site } from "@lib/site";

const faqItems = [
  {
    question: "Указана ли доставка в стоимости бетона?",
    answer: "Нет. В каталоге указана цена за 1 м³ бетона без учёта доставки. Итоговая стоимость рассчитывается индивидуально с учётом адреса объекта, объёма заказа и условий подъезда."
  },
  {
    question: "Как рассчитывается стоимость доставки?",
    answer: "Стоимость зависит от удалённости объекта, объёма заказа, количества необходимых машин, времени подачи и условий разгрузки. Для точного расчёта сообщите менеджеру адрес и основные параметры заказа."
  },
  {
    question: "Выполняете ли доставку по Московской области?",
    answer: "Да, доставляем бетон и строительные смеси по Москве и Московской области. Возможность и условия поставки по конкретному адресу уточнит менеджер."
  },
  {
    question: "Какой объём можно заказать?",
    answer: "Объём заказа рассчитывается в кубических метрах. Возможность поставки нужного объёма зависит от марки смеси, адреса объекта и графика производства и доставки."
  },
  {
    question: "Поможете подобрать подходящую марку бетона?",
    answer: "Да. Сообщите тип работ, назначение конструкции и условия эксплуатации — менеджер поможет подобрать подходящую марку и характеристики смеси."
  },
  {
    question: "Как оформить заявку?",
    answer: "Оставьте заявку через форму на сайте или свяжитесь с отделом продаж по телефону, в Telegram, WhatsApp или MAX. Укажите марку или задачу, объём и адрес доставки."
  }
];
---

<BaseLayout title={site.title} description={site.description} structuredData={[faqSchema(faqItems)]} showBottomMap={false}>
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">БЕТОН С ЗАВОДА В АПРЕЛЕВКЕ</p>
        <h1>Бетон с доставкой<br />по Москве и области</h1>
        <p class="lead">
          Подберём марку под задачу, рассчитаем бетон и доставку, согласуем время поставки на объект.
        </p>
        <div class="hero-actions">
          <a class="button button-accent hero-request-cta" href="#request">Получить расчёт</a>
          <a class="button hero-catalog-cta" href="/catalog/">Смотреть каталог и цены</a>
        </div>
        <div class="hero-contact-block" aria-label="Связаться с отделом продаж">
          <p>Связаться напрямую</p>
          <div class="hero-contact-phones">
            <a class="hero-phone-link" href={site.phonePrimaryHref}>{site.phonePrimary}</a>
            <a class="hero-phone-link hero-phone-link-secondary" href={site.phoneSecondaryHref}>{site.phoneSecondary}</a>
          </div>
          <div class="hero-contact-messengers">
            <a href={site.whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в WhatsApp">
              <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" />
              <span>WhatsApp</span>
            </a>
            <a href={site.telegramHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в Telegram">
              <img src="/icons/telegram.svg" alt="" aria-hidden="true" />
              <span>Telegram</span>
            </a>
            <a href={site.maxHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в MAX">
              <img src="/icons/max.svg" alt="" aria-hidden="true" />
              <span>MAX</span>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-media">
        <img src="/images/lider-beton-hero-zavod.webp" alt="Бетонный завод ЛИДЕР БЕТОН ГРУПП" loading="eager" />
        <div class="hero-media-card">
          <strong>Поставка с завода на объект</strong>
          <span>Москва и Московская область</span>
        </div>
      </div>
      <div class="hero-proof-strip" aria-label="Преимущества поставки">
        <div class="hero-proof-strip-inner">
          <div>
            <strong>Завод в Апрелевке</strong>
            <span>Собственная производственная площадка</span>
          </div>
          <div>
            <strong>Контроль состава</strong>
            <span>Подбор смеси под задачу</span>
          </div>
          <div>
            <strong>Доставка по Москве и МО</strong>
            <span>Расчёт под адрес и объём</span>
          </div>
          <div>
            <strong>Работаем ежедневно</strong>
            <span>Принимаем заявки и согласовываем поставки без выходных.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section prices-section" id="prices">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Цены</p>
        <h2>Цены на бетон и строительные смеси</h2>
        <p>Выберите категорию, чтобы посмотреть марки, позиции и стоимость за 1 м³. Итоговая стоимость доставки рассчитывается индивидуально.</p>
      </div>
      <CategoryGrid categories={categoryPages} variant="featured" />
    </div>
  </section>

  <section class="section section-white">
    <div class="container container-wide home-info-section home-production-section">
      <div class="section-title">
        <p class="eyebrow">Преимущества</p>
        <h2>Производство, контроль и доставка бетона</h2>
        <p>Производим бетон и растворы на площадке в Апрелевке, контролируем состав в лаборатории и организуем доставку по Москве и Московской области.</p>
      </div>
      <div class="home-info-grid">
        <article class="trust-card">
          <div class="trust-card-media">
            <img src="/images/lider-beton-aprelevka-plant.webp" alt="Завод по производству бетона в Апрелевке" loading="lazy" decoding="async" />
          </div>
          <div class="trust-card-body">
            <h3>Завод в Апрелевке</h3>
            <p>Производственная площадка для выпуска бетона и растворов. Удобная логистика для объектов в Москве и Московской области.</p>
          </div>
        </article>
        <article class="trust-card">
          <div class="trust-card-media">
            <img src="/images/lider-beton-laboratory.webp" alt="Лаборатория контроля качества бетонных смесей" loading="lazy" decoding="async" />
          </div>
          <div class="trust-card-body">
            <h3>Собственная лаборатория</h3>
            <p>Контроль состава и характеристик бетонных смесей. Помогаем подобрать марку под фундамент, монолитные работы и стяжки.</p>
          </div>
        </article>
        <article class="trust-card">
          <div class="trust-card-media">
            <img src="/images/lider-beton-delivery-mixers.webp" alt="Автобетоносмесители для доставки бетона на объект" loading="lazy" decoding="async" />
          </div>
          <div class="trust-card-body">
            <h3>Доставка под объект</h3>
            <p>Рассчитываем доставку по адресу и объёму, согласуем время поставки и удобный способ связи.</p>
          </div>
        </article>
      </div>
    </div>

    <div class="container container-relaxed home-order-section">
      <div class="section-title order-title">
        <p class="eyebrow">Заказ</p>
        <h2>Как заказать</h2>
        <p>Для расчёта достаточно указать марку, объём и адрес доставки. Позвоните, напишите в Telegram, WhatsApp или MAX — либо отправьте заявку через форму ниже.</p>
      </div>
      <div class="order-steps">
        <article class="order-step">
          <span>1</span>
          <h3>Свяжитесь с нами</h3>
          <p>Позвоните, напишите в Telegram, WhatsApp или MAX, либо заполните форму ниже.</p>
        </article>
        <article class="order-step">
          <span>2</span>
          <h3>Укажите данные</h3>
          <p>Сообщите марку бетона, объём и адрес доставки.</p>
        </article>
        <article class="order-step">
          <span>3</span>
          <h3>Получите расчёт</h3>
          <p>Рассчитаем стоимость смеси и доставки индивидуально.</p>
        </article>
        <article class="order-step">
          <span>4</span>
          <h3>Согласуйте поставку</h3>
          <p>Уточним детали заказа, время доставки и удобный способ связи.</p>
        </article>
      </div>
      <div class="order-cta">
        <p>Подготовьте марку, объём и адрес — рассчитаем стоимость под ваш объект.</p>
        <div class="order-cta-actions">
          <a class="button button-outline" href={site.phonePrimaryHref}>Позвонить</a>
          <MessengerIcons />
          <a class="button button-accent" href="#request">Перейти к заявке</a>
        </div>
      </div>
    </div>
  </section>

  <RequestSection />

  <section class="section section-white">
    <div class="container container-wide home-work-container">
      <div class="section-title">
        <p class="eyebrow">Примеры работ</p>
        <h2>Примеры поставки бетона на объекты</h2>
        <p>Поставляем бетон, растворы и строительные смеси для жилых, частных и промышленных объектов в Москве и Московской области.</p>
      </div>
      <div class="grid grid-3">
        <article class="work-card">
          <div class="work-card-media">
            <img src="/images/lider-beton-work-urban-delivery.webp" alt="Доставка бетона на жилой объект в Москве" loading="lazy" decoding="async" />
          </div>
          <div class="work-card-body">
            <h3>Доставка на жилой объект</h3>
            <p>Поставка бетонной смеси на городской объект с подачей к месту работ.</p>
          </div>
        </article>
        <article class="work-card">
          <div class="work-card-media">
            <img src="/images/lider-beton-work-pump-industrial.webp" alt="Подача бетона на строительной площадке с использованием бетононасоса" loading="lazy" decoding="async" />
          </div>
          <div class="work-card-body">
            <h3>Подача бетона на площадке</h3>
            <p>Работы с использованием техники для подачи бетонной смеси на объекте.</p>
          </div>
        </article>
        <article class="work-card">
          <div class="work-card-media">
            <img src="/images/lider-beton-work-private-slab.webp" alt="Бетонная плита под частный дом" loading="lazy" decoding="async" />
          </div>
          <div class="work-card-body">
            <h3>Плита под частный дом</h3>
            <p>Бетон для устройства основания и монолитных работ на частном объекте.</p>
          </div>
        </article>
      </div>
      <div class="work-actions">
        <a class="button button-outline" href="/primery-rabot/">Смотреть все примеры</a>
      </div>
    </div>
  </section>

  <section class="section reviews-section" id="reviews">
    <div class="container container-wide reviews-grid">
      <div class="reviews-copy">
        <div class="section-title">
          <p class="eyebrow">Отзывы</p>
          <h2>Отзывы клиентов</h2>
          <p>Отзывы о работе бетонного завода, доставке и подборе смесей.</p>
        </div>
        <div class="reviews-rating" aria-label="Рейтинг 4,3 из 5 на Яндекс Картах">
          <strong>4,3 <span>/ 5</span></strong>
          <p>6 отзывов · 8 оценок на Яндекс Картах</p>
        </div>
        <a
          class="button button-accent reviews-button"
          href="https://yandex.ru/maps/org/betonny_zavod_aprelevka/162300419291/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Смотреть на Яндекс Картах
        </a>
      </div>

      <div class="reviews-widget" aria-label="Отзывы на Яндекс Картах">
        <iframe
          src="https://yandex.ru/maps-reviews-widget/162300419291?comments"
          title="Отзывы о бетонном заводе Апрелевка на Яндекс Картах"
          loading="lazy"
        ></iframe>
        <a
          href="https://yandex.ru/maps/org/betonny_zavod_aprelevka/162300419291/"
          target="_blank"
          rel="noopener noreferrer"
        >
          Бетонный завод Апрелевка на карте Апрелевки — Яндекс Карты
        </a>
      </div>
    </div>
  </section>

  <section class="section section-white contact-map-section">
    <div class="container container-wide grid grid-2 home-map-container">
      <div class="contact-map-copy">
        <div class="section-title">
          <p class="eyebrow">Карта</p>
          <h2>Контакты и точка завода</h2>
          <p>Свяжитесь с отделом продаж — рассчитаем стоимость бетона и доставки по адресу объекта.</p>
        </div>
        <ul class="contact-info-list">
          <li><span>Точка завода</span><strong>Апрелевка, Сентябрьская ул., 12</strong></li>
          <li><span>Доставка</span><strong>Москва и Московская область</strong></li>
          <li><span>Расчёт</span><strong>по адресу и объёму</strong></li>
        </ul>
        <div class="contact-map-buttons">
          <a class="button button-primary" href={site.phonePrimaryHref}>+7 (495) 032-99-98</a>
          <a class="button button-outline" href={site.phoneSecondaryHref}>+7 (495) 032-60-40</a>
          <MessengerIcons />
        </div>
      </div>
      <div class="map-fallback-card">
        <div class="map-widget-frame">
          <iframe
            src={site.yandexMapWidgetSrc}
            title="Бетонный завод Апрелевка на Яндекс.Картах"
            width="100%"
            height="400"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0;"
            allowfullscreen
          ></iframe>
        </div>
        <div class="map-fallback-copy">
          <h3>Точка завода на Яндекс.Картах</h3>
          <p>Если карта не отображается, откройте точку завода в отдельном окне.</p>
          <a class="button button-accent" href={site.yandexMapHref} target="_blank" rel="noopener noreferrer">
            Открыть точку на Яндекс.Картах
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="section home-faq-section">
    <div class="container container-relaxed home-faq-grid">
      <div class="home-faq-copy">
        <div class="section-title home-faq-title">
          <p class="eyebrow">FAQ</p>
          <h2>Частые вопросы</h2>
          <p>Ответили на основные вопросы о ценах, доставке, подборе бетона и оформлении заказа.</p>
        </div>
        <div class="home-faq-cta">
          <p>Не нашли нужную информацию? Сообщите параметры объекта — менеджер уточнит детали и подготовит расчёт.</p>
          <a class="button button-accent" href="#request">Получить расчёт</a>
        </div>
      </div>
      <div class="faq-list home-faq-list">
        {faqItems.map((item, index) => (
          <details class="faq-item home-faq-item" name="home-faq" open={index === 0}>
            <summary>
              <span class="faq-number">{String(index + 1).padStart(2, "0")}</span>
              <span class="faq-question">{item.question}</span>
            </summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
