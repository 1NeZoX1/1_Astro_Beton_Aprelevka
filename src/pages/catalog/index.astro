---
import CategoryGrid from "@components/CategoryGrid.astro";
import ProductCard from "@components/ProductCard.astro";
import RequestSection from "@components/RequestSection.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { categoryPages, getPopularProducts } from "@lib/catalog";

const title = "Каталог бетона и строительных смесей";
const description =
  "Каталог бетона с доставкой по Москве и Московской области: категории, карточки товаров, цены и заявка на заказ.";
const subtitle = "Выберите категорию и оставьте заявку — стоимость доставки рассчитывается индивидуально.";
const popularProducts = getPopularProducts(6);
---

<BaseLayout title={title} description={description}>
  <section class="section-tight">
    <div class="container">
      <div class="section-title">
        <h1>{title}</h1>
        <p>{subtitle}</p>
      </div>

      <CategoryGrid categories={categoryPages} />
    </div>
  </section>

  <section class="section section-white">
    <div class="container">
      <div class="section-title">
        <p class="eyebrow">Популярные позиции</p>
        <h2>Часто выбирают</h2>
        <p>Популярные позиции для фундамента, монолитных работ, подачи бетона и строительных растворов.</p>
      </div>
      <div class="grid grid-3 popular-products-grid">
        {popularProducts.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>

  <RequestSection />
</BaseLayout>

<style>
  .popular-products-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  @media (max-width: 980px) {
    .popular-products-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 680px) {
    .popular-products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
