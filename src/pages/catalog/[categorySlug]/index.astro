---
import Breadcrumbs from "@components/Breadcrumbs.astro";
import ProductCard from "@components/ProductCard.astro";
import RequestForm from "@components/RequestForm.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  CPS_PRODUCT_TYPES,
  EQUIPMENT_SERVICE_TYPES,
  KERAMZIT_CLASSES,
  PMD_GROUPS,
  PRODUCT_MARKS,
  categories,
  categoryPages,
  getCpsProductType,
  getEquipmentServiceType,
  getProductClassLabel,
  getProductMarkLabel,
  sortProductsByMarkPriceName,
  type CategoryPage,
  type Product
} from "@lib/catalog";
import { breadcrumbSchema } from "@lib/schema";

export function getStaticPaths() {
  return categoryPages.map((category) => ({
    params: { categorySlug: category.slug },
    props: { category }
  }));
}

type Props = {
  category: CategoryPage;
};

const { category } = Astro.props;
const isConcreteCategory = category.slug === "beton";
const isPmdCategory = category.slug === "beton-s-pmd";
const pmdGroupOrder = new Map<string, number>(PMD_GROUPS.map((group, index) => [group, index]));

type CatalogFilterPanel = {
  label: string;
  value: string;
  products: Product[];
};

const CONCRETE_FILTERS = [
  { label: "На граните", slug: "granit" },
  { label: "На гравии", slug: "graviy" },
  { label: "Товарный", slug: "tovarnyy-beton" },
  { label: "Гидротехнический", slug: "gidrotehnicheskiy-beton" },
  { label: "На мелком щебне", slug: "melkiy-scheben" },
  { label: "Схема Г", slug: "shema-g" },
  { label: "Тощий", slug: "toschiy-beton" },
  { label: "Другое", slug: "drugoe" }
] as const;

function getFilterValue(label: string): string {
  return label
    .toLowerCase()
    .replace(/\s*\/\s*/g, "-")
    .replace(/\s+/g, "-")
    .replace(/[^\p{L}\p{N}.-]+/gu, "-")
    .replace(/^-+|-+$/g, "");
}

function sortPmdProducts(a: Product, b: Product): number {
  const groupA = pmdGroupOrder.get(a.pmdGroup ?? "Другое") ?? PMD_GROUPS.length;
  const groupB = pmdGroupOrder.get(b.pmdGroup ?? "Другое") ?? PMD_GROUPS.length;

  if (groupA !== groupB) {
    return groupA - groupB;
  }

  return sortProductsByMarkPriceName(a, b);
}

function buildCatalogFilters(
  allProducts: Product[],
  labels: readonly string[],
  getProductFilterLabel: (product: Product) => string | undefined,
  valuesByLabel: Map<string, string> = new Map()
): CatalogFilterPanel[] {
  const filters = labels
    .map((label) => ({
      label,
      value: valuesByLabel.get(label) ?? getFilterValue(label),
      products: allProducts.filter((product) => getProductFilterLabel(product) === label)
    }))
    .filter((filter) => filter.products.length > 0);

  if (filters.length <= 1) {
    return [{ label: "Все", value: "", products: allProducts }];
  }

  return [{ label: "Все", value: "", products: allProducts }, ...filters];
}

function getCatalogFilterPanels(categorySlug: string, products: Product[]): CatalogFilterPanel[] {
  if (categorySlug === "beton-s-pmd") {
    const sortedPmdProducts = [...products].sort(sortPmdProducts);
    const pmdValues = new Map(PMD_GROUPS.map((group) => [group, group.replace("ПМД-", "")]));

    return buildCatalogFilters(
      sortedPmdProducts,
      PMD_GROUPS.filter((group) => group !== "Другое"),
      (product) => product.pmdGroup,
      pmdValues
    );
  }

  const sortedProducts = [...products].sort(sortProductsByMarkPriceName);

  if (categorySlug === "beton") {
    const valuesByLabel = new Map(CONCRETE_FILTERS.map((filter) => [filter.label, filter.slug]));

    return buildCatalogFilters(
      sortedProducts,
      CONCRETE_FILTERS.map((filter) => filter.label),
      (product) =>
        CONCRETE_FILTERS.find((filter) => filter.slug === product.concreteSubcategorySlug)?.label,
      valuesByLabel
    );
  }

  if (categorySlug === "fibrobeton" || categorySlug === "suhoy-beton") {
    return buildCatalogFilters(sortedProducts, PRODUCT_MARKS, (product) =>
      getProductMarkLabel(product.title)
    );
  }

  if (categorySlug === "keramzitobeton") {
    return buildCatalogFilters(sortedProducts, KERAMZIT_CLASSES, (product) =>
      getProductClassLabel(product.title)
    );
  }

  if (categorySlug === "rastvory-i-cps") {
    return buildCatalogFilters(sortedProducts, CPS_PRODUCT_TYPES, getCpsProductType);
  }

  if (categorySlug === "arenda-tehniki") {
    return buildCatalogFilters(sortedProducts, EQUIPMENT_SERVICE_TYPES, getEquipmentServiceType);
  }

  return [{ label: "Все", value: "", products: sortedProducts }];
}

const catalogFilterPanels = getCatalogFilterPanels(category.slug, category.products);
const hasCatalogFilters = catalogFilterPanels.length > 1;
const catalogFilterParam = isPmdCategory ? "pmd" : isConcreteCategory ? "sub" : "";
const sortedCategoryProducts = catalogFilterPanels[0].products;
const canonicalBase = Astro.site ?? "https://example.com";
const crumbs = [
  { label: "Главная", href: "/" },
  { label: "Каталог", href: "/catalog/" },
  { label: category.title }
];
const schema = breadcrumbSchema([
  { name: "Главная", url: new URL("/", canonicalBase).toString() },
  { name: "Каталог", url: new URL("/catalog/", canonicalBase).toString() },
  { name: category.title, url: new URL(`/catalog/${category.slug}/`, canonicalBase).toString() }
]);
---

<BaseLayout title={category.seoTitle} description={category.seoDescription} structuredData={[schema]}>
  <section class="section-tight">
    <div class="container">
      <Breadcrumbs items={crumbs} />
      <div class="section-title">
        <p class="eyebrow">Категория</p>
        <h1>{category.title}</h1>
        <p>{category.description}</p>
      </div>

      <nav class="category-tabs" aria-label="Категории каталога">
        {categories.map((item) => (
          <a class={item.slug === category.slug ? "is-active" : ""} href={`/catalog/${item.slug}/`}>
            {item.title}
          </a>
        ))}
      </nav>

      <div class="catalog-products-heading">
        <h2>Марки и цены</h2>
        <p>
          {isConcreteCategory
            ? "Выберите тип бетона или оставьте заявку — менеджер рассчитает итоговую стоимость с доставкой."
            : isPmdCategory
              ? "Выберите температурную группу ПМД или оставьте заявку — менеджер подберет бетон под условия объекта."
              : "Выберите позицию или оставьте заявку — менеджер рассчитает итоговую стоимость с доставкой."}
        </p>
      </div>

      {hasCatalogFilters && (
        <nav
          class="catalog-filter"
          aria-label="Фильтр товаров"
          data-catalog-filter
          data-filter-param={catalogFilterParam}
        >
          {catalogFilterPanels.map((filter) => (
            <button
              class={`catalog-filter-chip ${filter.value === "" ? "is-active" : ""}`}
              type="button"
              data-catalog-filter-tab={filter.value}
              aria-selected={filter.value === "" ? "true" : "false"}
            >
              <span>{filter.label}</span>
              <span>{filter.products.length}</span>
            </button>
          ))}
        </nav>
      )}

      {hasCatalogFilters ? (
        <div class="catalog-filter-panels">
          {catalogFilterPanels.map((filter) => (
            <section
              class="catalog-filter-panel"
              data-catalog-filter-panel={filter.value}
              hidden={filter.value !== ""}
            >
              <div class="grid grid-3 product-grid">
                {filter.products.map((product) => <ProductCard product={product} />)}
              </div>
            </section>
          ))}
        </div>
      ) : sortedCategoryProducts.length > 0 ? (
        <div class="grid grid-3 product-grid">
          {sortedCategoryProducts.map((product) => <ProductCard product={product} />)}
        </div>
      ) : (
        <div class="catalog-empty">
          <h2>Товары этой категории скоро появятся</h2>
          <p>Оставьте заявку, и мы уточним доступные позиции и стоимость доставки.</p>
        </div>
      )}
    </div>
  </section>

  <section class="section section-white">
    <div class="container request-panel">
      <div class="section-title">
        <p class="eyebrow">Заказ</p>
        <h2>Заказать {category.title.toLowerCase()}</h2>
        <p>Оставьте контакты, и заявка откроется в WhatsApp с заполненным текстом.</p>
      </div>
      <RequestForm productTitle={category.title} />
    </div>
  </section>

  {hasCatalogFilters && (
    <script is:inline>
      const catalogFilterRoot = document.querySelector("[data-catalog-filter]");
      const catalogFilterButtons = document.querySelectorAll("[data-catalog-filter-tab]");
      const catalogFilterPanels = document.querySelectorAll("[data-catalog-filter-panel]");
      const catalogFilterParam = catalogFilterRoot?.getAttribute("data-filter-param") ?? "";

      function activateCatalogFilter(value) {
        const normalizedValue = value ?? "";

        catalogFilterButtons.forEach((button) => {
          const isActive = button.getAttribute("data-catalog-filter-tab") === normalizedValue;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-selected", isActive ? "true" : "false");
        });

        catalogFilterPanels.forEach((panel) => {
          panel.hidden = panel.getAttribute("data-catalog-filter-panel") !== normalizedValue;
        });

        if (catalogFilterParam) {
          const url = new URL(window.location.href);
          if (normalizedValue) {
            url.searchParams.set(catalogFilterParam, normalizedValue);
          } else {
            url.searchParams.delete(catalogFilterParam);
          }
          window.history.replaceState(null, "", url);
        }
      }

      const initialCatalogFilter = catalogFilterParam
        ? new URLSearchParams(window.location.search).get(catalogFilterParam) ?? ""
        : "";

      if (document.querySelector(`[data-catalog-filter-panel="${initialCatalogFilter}"]`)) {
        activateCatalogFilter(initialCatalogFilter);
      }

      catalogFilterButtons.forEach((button) => {
        button.addEventListener("click", () => {
          activateCatalogFilter(button.getAttribute("data-catalog-filter-tab"));
        });
      });
    </script>
  )}
</BaseLayout>
