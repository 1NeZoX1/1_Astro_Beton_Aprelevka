---
import { formatProductPrice, getProductSpecs, type Product } from "@lib/catalog";

type Props = {
  product: Product;
};

const { product } = Astro.props;
const href = product.categorySlug && product.slug ? `/catalog/${product.categorySlug}/${product.slug}/` : "/catalog/";
const specs = getProductSpecs(product.title);
const mark = specs.find((spec) => spec.label === "Марка")?.value;
const specPriority = ["Класс", "Подвижность", "Морозостойкость", "Водонепроницаемость"];
const visibleSpecs = specPriority
  .flatMap((label) => {
    const spec = specs.find((item) => item.label === label);
    return spec ? [spec] : [];
  })
  .slice(0, 4);
const badge = product.concreteSubcategory ?? product.category;

function getDisplayTitle() {
  if (product.pmdGroup || product.categorySlug === "beton-s-pmd") {
    return "Бетон с ПМД";
  }

  if (product.concreteSubcategory && product.concreteSubcategory !== "Другое") {
    return product.concreteSubcategory;
  }

  const normalized = product.title
    .replace(/\s+[МM]\d+/gi, "")
    .replace(/\s+[BВ]\d+(?:[.,]\d+)?/gi, "")
    .replace(/\s+П\d+(?:\/П?\d+)?/gi, "")
    .replace(/\s+F\d+/gi, "")
    .replace(/\s+W\d+/gi, "")
    .replace(/\s+\d+(?:-\d+)?\s*м\.?/gi, "")
    .replace(/\s+/g, " ")
    .trim();

  return normalized || badge;
}

const displayTitle = getDisplayTitle();
---

<article class="product-card">
  <div class="product-card-body">
    <div class="product-card-top">
      <a class="product-title-pill" href={href} title={product.title}>{displayTitle}</a>
      {mark && <span class="product-mark">{mark}</span>}
    </div>
    {visibleSpecs.length > 0 && (
      <ul class="product-spec-chips" aria-label="Характеристики">
        {visibleSpecs.map((spec) => <li>{spec.value}</li>)}
      </ul>
    )}
    <div class="product-card-footer">
      <strong class="product-price">{formatProductPrice(product)}</strong>
      <div class="card-actions">
        <a class="button button-small button-outline" href={href}>Подробнее</a>
        <a class="button button-small button-accent" href="#request">Заказать</a>
      </div>
    </div>
  </div>
</article>
