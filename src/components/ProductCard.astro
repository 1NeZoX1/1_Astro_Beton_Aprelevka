---
import { formatProductPrice, getProductSpecs, type Product } from "@lib/catalog";

type Props = {
  product: Product;
};

const { product } = Astro.props;
const href = product.categorySlug && product.slug ? `/catalog/${product.categorySlug}/${product.slug}/` : "/catalog/";
const specs = getProductSpecs(product.title);
const mark = specs.find((spec) => spec.label === "Марка")?.value;
const visibleSpecs = specs.filter((spec) => spec.label !== "Марка");
const badge = product.concreteSubcategory ?? product.category;
---

<article class="product-card">
  <div class="product-card-body">
    <div class="product-card-top">
      <span class="product-badge-group">
        <span class="product-badge">{badge}</span>
        {product.pmdGroup && <span class="product-badge product-badge-secondary">{product.pmdGroup}</span>}
      </span>
      {mark && <span class="product-mark">{mark}</span>}
    </div>
    <h3><a href={href}>{product.title}</a></h3>
    {visibleSpecs.length > 0 && (
      <ul class="product-spec-chips" aria-label="Характеристики">
        {visibleSpecs.map((spec) => <li>{spec.value}</li>)}
      </ul>
    )}
    <div class="product-card-footer">
      <strong class="product-price">{formatProductPrice(product)}</strong>
      <div class="card-actions">
        <a class="button button-small button-outline" href={href}>Подробнее</a>
        <a class="button button-small button-accent" href="#request">Заказать</a>
      </div>
    </div>
  </div>
</article>
