---
import { navItems, site } from "@lib/site";
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-about">
      <a class="brand footer-brand" href="/">
        <span class="brand-mark">LBG</span>
        <span class="brand-text">{site.name}</span>
      </a>
      <p class="footer-legal">{site.legalName}</p>
      <p class="footer-description">Поставка бетона, растворов и строительных смесей по Москве и Московской области.</p>
      <p class="footer-address">Апрелевка, Сентябрьская ул., 12</p>
    </div>

    <nav class="footer-nav" aria-label="Навигация в подвале">
      <h3>Разделы</h3>
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="/politika-konfidentsialnosti/">Политика конфиденциальности</a>
    </nav>

    <div class="footer-contacts">
      <h3>Связаться</h3>
      <a href={site.phonePrimaryHref}>{site.phonePrimary}</a>
      <a href={site.phoneSecondaryHref}>{site.phoneSecondary}</a>
      <p class="footer-messenger-title">Мессенджеры:</p>
      <div class="footer-messenger-links">
        <a href={site.whatsappHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в WhatsApp">
          <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" />
          <span>WhatsApp</span>
        </a>
        <a href={site.maxHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в MAX">
          <img src="/icons/max.svg" alt="" aria-hidden="true" />
          <span>MAX</span>
        </a>
        <a href={site.telegramHref} target="_blank" rel="noopener noreferrer" aria-label="Написать в Telegram">
          <img src="/icons/telegram.svg" alt="" aria-hidden="true" />
          <span>Telegram</span>
        </a>
      </div>
      <a class="button button-accent footer-button" href="/kontakty/#request">Заказать бетон</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>© 2026 {site.legalName}</p>
    <p>Цены на сайте указаны за 1 м³ без учёта доставки. Итоговая стоимость рассчитывается индивидуально.</p>
    <a href="/politika-konfidentsialnosti/">Политика конфиденциальности</a>
  </div>
</footer>
