---
import { site } from "@lib/site";

type Props = {
  productTitle?: string;
};

const { productTitle = "" } = Astro.props;
---

<form class="request-form js-request-form" id="request" data-telegram-href={site.telegramHref}>
  <div class="form-head">
    <p class="eyebrow">Заявка</p>
    <h3>Получить расчёт</h3>
    <p>Заполните поля — Telegram откроется для отправки заявки, а MAX можно открыть для связи.</p>
  </div>
  <div class="form-grid">
    <label>
      <span>Имя</span>
      <input name="name" autocomplete="name" placeholder="Ваше имя" />
    </label>
    <label>
      <span>Телефон</span>
      <input name="phone" autocomplete="tel" inputmode="tel" placeholder="+7" required />
    </label>
    <label class="form-wide">
      <span>Что хотите заказать</span>
      <input name="product" value={productTitle} placeholder="Марка бетона, объем" />
    </label>
    <label class="form-wide">
      <span>Адрес доставки</span>
      <input name="address" placeholder="Город, улица, объект" />
    </label>
    <label class="form-wide">
      <span>Комментарий</span>
      <textarea name="comment" rows="4" placeholder="Удобное время, подъезд, пожелания"></textarea>
    </label>
  </div>
  <div class="form-actions">
    <button class="button button-accent" type="submit">Отправить в Telegram</button>
    <a class="button button-outline" href={site.maxHref} target="_blank" rel="noopener noreferrer">Открыть MAX</a>
    <a class="button button-outline" href={site.phonePrimaryHref}>Позвонить</a>
  </div>
  <p class="form-note">
    После нажатия откроется Telegram для отправки заявки.
  </p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>(".js-request-form").forEach((form) => {
    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const data = new FormData(form);
      const text = [
        "Здравствуйте! Хочу заказать бетон.",
        `Имя: ${data.get("name") || ""}`,
        `Телефон: ${data.get("phone") || ""}`,
        `Товар/объем: ${data.get("product") || ""}`,
        `Адрес доставки: ${data.get("address") || ""}`,
        `Комментарий: ${data.get("comment") || ""}`
      ].join("\n");

      void text;
      const telegramHref = form.dataset.telegramHref || "https://t.me/+79516457971";
      const telegramWindow = window.open(telegramHref, "_blank", "noopener,noreferrer");
      if (!telegramWindow) {
        window.location.href = telegramHref;
      }
    });
  });
</script>
